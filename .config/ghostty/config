# ============================================
# Ghostty Terminal Configuration
# Optimized for Rust / Git / Blockchain Dev
# ============================================


# Typography
font-family = Maple Mono NF CN
font-size = 15
font-thicken = true
adjust-cell-height = 6


# Theme
# Catppuccin: soft, low-saturation, auto light/dark
theme = dark:Kanagawa Wave,light:Kanagawa Light
background-opacity = 0.95
window-theme = auto


# Window
macos-titlebar-style = transparent
window-padding-x = 14
window-padding-y = 10
window-save-state = always


# Cursor
cursor-style = bar
cursor-style-blink = false


# Mouse
mouse-hide-while-typing = true
copy-on-select = clipboard


# Quick Terminal (global Quake-style dropdown)
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.15


# Close behavior
confirm-close-surface = false


# Security
# Critical for blockchain dev: prevents malicious clipboard injection
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true


# Shell Integration
shell-integration = detect
shell-integration-features = cursor,sudo,no-title,ssh-env,ssh-terminfo,path


# Performance
# 10000 lines is sufficient; use file redirection for long logs
scrollback-limit = 10000


# macOS
# Required for vim / tmux alt-key bindings
macos-option-as-alt = true


# Keybindings
# Quick terminal global hotkey (works in any app)
keybind = global:ctrl+grave_accent=toggle_quick_terminal
